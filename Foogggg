local function searchScriptBlox(query)
    for _, child in pairs(resultsScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    addConsoleLog("Searching ScriptBlox: " .. query, "info")

    local url = "https://scriptblox.com/api/script/search?q=" .. HttpService:UrlEncode(query)
    local ok, response = pcall(function() return game:HttpGet(url) end)

    if ok then
        local decOk, data = pcall(function() return HttpService:JSONDecode(response) end)
        if decOk and data.result and data.result.scripts then
            addConsoleLog("Found " .. #data.result.scripts .. " results", "success")
            for i, script in pairs(data.result.scripts) do
                if i > 12 then break end

