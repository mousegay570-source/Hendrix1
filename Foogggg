-- Console log storage
local consoleLogs = {}
local consoleFrame = nil
local consoleScroll = nil
local consoleLayout = nil

local function addConsoleLog(msg, logType)
    local color = Color3.fromRGB(200, 200, 200)
    if logType == "error" then
        color = Color3.fromRGB(255, 80, 80)
    elseif logType == "success" then
        color = Color3.fromRGB(80, 255, 80)
    elseif logType == "warn" then
        color = Color3.fromRGB(255, 200, 80)
    elseif logType == "info" then
        color = Color3.fromRGB(100, 180, 255)
    end

    table.insert(consoleLogs, {msg = msg, color = color})

    if consoleScroll and consoleLayout then
        local logLabel = Instance.new("TextLabel")
        logLabel.Size = UDim2.new(1, -8, 0, 0)
        logLabel.AutomaticSize = Enum.AutomaticSize.Y
        logLabel.BackgroundTransparency = 1
        logLabel.Text = "[" .. os.date("%H:%M:%S") .. "] " .. tostring(msg)
        logLabel.TextColor3 = color
        logLabel.Font = Enum.Font.Code
        logLabel.TextSize = 11
        logLabel.TextXAlignment = Enum.TextXAlignment.Left
        logLabel.TextWrapped = true
        logLabel.Parent = consoleScroll

        consoleScroll.CanvasSize = UDim2.new(0, 0, 0, consoleLayout.AbsoluteContentSize.Y + 10)
        consoleScroll.CanvasPosition = Vector2.new(0, consoleLayout.AbsoluteContentSize.Y)
    end
end

-- Hook print/warn/error ke console
local oldPrint = print
local oldWarn = warn
local oldError = error

print = function(...)
    local args = {...}
    local msg = table.concat(args, " ")
    oldPrint(msg)
    addConsoleLog(msg, "print")
end

warn = function(...)
    local args = {...}
    local msg = table.concat(args, " ")
    oldWarn(msg)
    addConsoleLog(msg, "warn")
end

