                    addConsoleLog("Copied: " .. (script.title or "script"), "info")
                    copyBtn.Text = "✓ Copied"; copyBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
                    task.wait(1)
                    copyBtn.Text = "Copy"; copyBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
                end)
            end

            resultsLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                resultsScroll.CanvasSize = UDim2.new(0, 0, 0, resultsLayout.AbsoluteContentSize.Y + 10)
            end)
            resultsScroll.CanvasSize = UDim2.new(0, 0, 0, resultsLayout.AbsoluteContentSize.Y + 10)
        else
            addConsoleLog("No results found for: " .. query, "warn")
            local err = Instance.new("TextLabel")
            err.Size = UDim2.new(1, 0, 0, 50)
            err.BackgroundTransparency = 1
            err.Text = "No results found"
            err.TextColor3 = Color3.fromRGB(255, 100, 100)
            err.Font = Enum.Font.GothamBold
            err.TextSize = 14
            err.Parent = resultsScroll
        end
    else
        addConsoleLog("HTTP Error fetching scripts", "error")
        local err = Instance.new("TextLabel")
        err.Size = UDim2.new(1, 0, 0, 50)
        err.BackgroundTransparency = 1
        err.Text = "Error: Could not fetch scripts"
        err.TextColor3 = Color3.fromRGB(255, 100, 100)
        err.Font = Enum.Font.GothamBold
        err.TextSize = 14
        err.Parent = resultsScroll
    end
end

