-- Fungsi search dari ScriptBlox
local function searchScriptBlox(query)
    -- Clear previous results
    for _, child in pairs(resultsScroll:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    local HttpService = game:GetService("HttpService")
    local url = "https://scriptblox.com/api/script/search?q=" .. HttpService:UrlEncode(query)
    
    local success, response = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success then
        local decodeSuccess, data = pcall(function()
            return HttpService:JSONDecode(response)
        end)
        
        if decodeSuccess and data.result and data.result.scripts then
            for i, script in pairs(data.result.scripts) do
                if i > 12 then break end
                
                local scriptFrame = Instance.new("Frame")
                scriptFrame.Size = UDim2.new(1, -8, 0, 70)
                scriptFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                scriptFrame.BorderSizePixel = 0
                scriptFrame.Parent = resultsScroll
                
                local scriptCorner = Instance.new("UICorner")
                scriptCorner.CornerRadius = UDim.new(0, 5)
                scriptCorner.Parent = scriptFrame
                
                local scriptStroke = Instance.new("UIStroke")
                scriptStroke.Color = Color3.fromRGB(138, 43, 226)
                scriptStroke.Thickness = 1
                scriptStroke.Transparency = 0.5
                scriptStroke.Parent = scriptFrame
                
                local scriptName = Instance.new("TextLabel")
                scriptName.Size = UDim2.new(1, -10, 0, 20)
                scriptName.Position = UDim2.new(0, 5, 0, 5)
                scriptName.BackgroundTransparency = 1
                scriptName.Text = script.title or "Unnamed Script"
                scriptName.TextColor3 = Color3.fromRGB(138, 43, 226)
                scriptName.Font = Enum.Font.GothamBold
                scriptName.TextSize = 12
                scriptName.TextXAlignment = Enum.TextXAlignment.Left
                scriptName.TextTruncate = Enum.TextTruncate.AtEnd
                scriptName.Parent = scriptFrame
                
                local scriptGame = Instance.new("TextLabel")
                scriptGame.Size = UDim2.new(1, -10, 0, 16)
                scriptGame.Position = UDim2.new(0, 5, 0, 25)
                scriptGame.BackgroundTransparency = 1
                scriptGame.Text = "Game: " .. (script.game and script.game.name or "Universal")
                scriptGame.TextColor3 = Color3.fromRGB(180, 180, 180)
                scriptGame.Font = Enum.Font.Gotham
                scriptGame.TextSize = 10
                scriptGame.TextXAlignment = Enum.TextXAlignment.Left
                scriptGame.Parent = scriptFrame
                
                -- Execute Button
                local exeBtn = Instance.new("TextButton")
                exeBtn.Size = UDim2.new(0, 55, 0, 24)
                exeBtn.Position = UDim2.new(1, -125, 0, 42)
                exeBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
                exeBtn.Text = "Execute"
                exeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                exeBtn.Font = Enum.Font.GothamBold
                exeBtn.TextSize = 10
                exeBtn.Parent = scriptFrame
                
                local exeCorner = Instance.new("UICorner")
                exeCorner.CornerRadius = UDim.new(0, 4)
                exeCorner.Parent = exeBtn
                
                -- Copy Button
                local copyBtn = Instance.new("TextButton")
                copyBtn.Size = UDim2.new(0, 55, 0, 24)
                copyBtn.Position = UDim2.new(1, -62, 0, 42)
                copyBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
                copyBtn.Text = "Copy"
                copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                copyBtn.Font = Enum.Font.GothamBold
                copyBtn.TextSize = 10
                copyBtn.Parent = scriptFrame
                
                local copyCorner = Instance.new("UICorner")
                copyCorner.CornerRadius = UDim.new(0, 4)
                copyCorner.Parent = copyBtn
                
                -- Execute functionality
                exeBtn.MouseButton1Click:Connect(function()
                    local scriptContent = script.script or ""
                    local execSuccess, execError = pcall(function()
                        loadstring(scriptContent)()
                    end)
                    
                    if execSuccess then
                        exeBtn.Text = "✓ Done"
                        exeBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                        task.wait(1.5)
                        exeBtn.Text = "Execute"
                        exeBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
                    else
                        exeBtn.Text = "✗ Error"
                        exeBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                        task.wait(1.5)
                        exeBtn.Text = "Execute"
                        exeBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
                    end
                end)
                
                -- Copy functionality
                copyBtn.MouseButton1Click:Connect(function()
                    setclipboard(script.script or "")
                    copyBtn.Text = "✓ Copied"
                    copyBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
                    task.wait(1)
                    copyBtn.Text = "Copy"
                    copyBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
                end)
            end
            
            resultsScroll.CanvasSize = UDim2.new(0, 0, 0, resultsLayout.AbsoluteContentSize.Y + 10)
        else
            local errorLabel = Instance.new("TextLabel")
            errorLabel.Size = UDim2.new(1, 0, 0, 50)
            errorLabel.BackgroundTransparency = 1
            errorLabel.Text = "No results found"
            errorLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            errorLabel.Font = Enum.Font.GothamBold
            errorLabel.TextSize = 14
            errorLabel.Parent = resultsScroll
        end
    else
        local errorLabel = Instance.new("TextLabel")
        errorLabel.Size = UDim2.new(1, 0, 0, 50)
        errorLabel.BackgroundTransparency = 1
        errorLabel.Text = "Error: Could not fetch scripts"
        errorLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        errorLabel.Font = Enum.Font.GothamBold
        errorLabel.TextSize = 14
        errorLabel.Parent = resultsScroll
    end
end

