editorExeBtn.MouseButton1Click:Connect(function()
    local code = scriptEditor.Text
    if code ~= "" then
        local success, err = pcall(function()
            loadstring(code)()
        end)
        
        if success then
            editorExeBtn.Text = "✓ Success"
            editorExeBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
            task.wait(1.5)
            editorExeBtn.Text = "Execute"
            editorExeBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        else
            editorExeBtn.Text = "✗ Error"
            editorExeBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            warn("Script Error:", err)
            task.wait(1.5)
            editorExeBtn.Text = "Execute"
            editorExeBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        end
    end
end)

